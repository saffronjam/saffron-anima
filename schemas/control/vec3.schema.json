{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "vec3.schema.json",
  "title": "Vec3",
  "description": "Three-component float vector.",
  "type": "object",
  "properties": {
    "x": { "type": "number" },
    "y": { "type": "number" },
    "z": { "type": "number" }
  },
  "required": ["x", "y", "z"],
  "additionalProperties": false
}
