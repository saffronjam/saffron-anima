{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "directional-light.schema.json",
  "title": "DirectionalLight",
  "description": "Directional light component (sun-style light with a direction, color, intensity, and ambient term).",
  "type": "object",
  "properties": {
    "direction": { "$ref": "vec3.schema.json" },
    "color": { "$ref": "vec3.schema.json" },
    "intensity": { "type": "number" },
    "ambient": { "type": "number" }
  },
  "required": ["direction", "color", "intensity", "ambient"],
  "additionalProperties": false
}
