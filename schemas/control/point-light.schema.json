{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "point-light.schema.json",
  "title": "PointLight",
  "description": "Point light component (omnidirectional light with color, intensity, and range).",
  "type": "object",
  "properties": {
    "color": { "$ref": "vec3.schema.json" },
    "intensity": { "type": "number" },
    "range": { "type": "number" }
  },
  "required": ["color", "intensity", "range"],
  "additionalProperties": false
}
