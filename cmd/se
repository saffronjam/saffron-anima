#!/usr/bin/env python3
"""Wrapper for the se control CLI. Handles 'start'; delegates everything else to the binary."""

import os
import subprocess
import sys
import time
from pathlib import Path

REPO_ROOT = Path(__file__).resolve().parent.parent
EDITOR_BIN = REPO_ROOT / "build/debug/bin/SaffronEditor"
SE_BIN = REPO_ROOT / "build/debug/bin/se"


def socket_path() -> str:
    if override := os.environ.get("SAFFRON_CONTROL_SOCK"):
        return override
    if runtime := os.environ.get("XDG_RUNTIME_DIR"):
        return f"{runtime}/saffron-control.sock"
    return f"/tmp/saffron-control-{os.getuid()}.sock"


def is_engine_running(path: str) -> bool:
    if not os.path.exists(path):
        return False
    try:
        import socket as _socket
        s = _socket.socket(_socket.AF_UNIX, _socket.SOCK_STREAM)
        s.connect(path)
        s.close()
        return True
    except OSError:
        os.unlink(path)
        return False


def cmd_build() -> int:
    print("se: building...")
    result = subprocess.run(
        ["toolbox", "run", "-c", "saffron-build", "cmake", "--build",
         str(REPO_ROOT / "build/debug")],
    )
    return result.returncode


def cmd_start(attach: bool, build: bool) -> int:
    if build:
        rc = cmd_build()
        if rc != 0:
            return rc
    path = socket_path()
    if is_engine_running(path):
        print("se: engine already running")
        return 0
    if not EDITOR_BIN.exists():
        print(f"se: editor binary not found: {EDITOR_BIN}", file=sys.stderr)
        print("se: hint: se start --build", file=sys.stderr)
        return 1
    toolbox_cmd = ["toolbox", "run", "-c", "saffron-build", str(EDITOR_BIN)]
    if attach:
        os.execv("/usr/bin/toolbox", toolbox_cmd)
    subprocess.Popen(
        toolbox_cmd,
        start_new_session=True,
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
    )
    for _ in range(20):
        time.sleep(0.25)
        if os.path.exists(path):
            print("se: engine started")
            return 0
    print("se: engine launched but socket not yet ready — it may still be initialising", file=sys.stderr)
    return 0


def main() -> int:
    if len(sys.argv) < 2:
        print("usage: se <command> [positional...] [-o text|json] [--flag value]", file=sys.stderr)
        return 2

    if sys.argv[1] == "start":
        unknown = [a for a in sys.argv[2:] if a not in ("--attach", "--build")]
        if unknown:
            print(f"se start: unknown argument(s): {' '.join(unknown)}", file=sys.stderr)
            print("se start: usage: se start [--attach] [--build]", file=sys.stderr)
            return 1
        return cmd_start("--attach" in sys.argv, "--build" in sys.argv)

    if not SE_BIN.exists():
        print(f"se: binary not found: {SE_BIN}", file=sys.stderr)
        print("se: run: cmake --build build/debug --target se", file=sys.stderr)
        return 1

    os.execv(str(SE_BIN), [str(SE_BIN)] + sys.argv[1:])


sys.exit(main())
